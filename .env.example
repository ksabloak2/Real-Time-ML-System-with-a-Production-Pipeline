# ── Ingestion settings ─────────────────────────────────────────────────────────
# No Reddit API credentials needed — uses the public JSON feed
REDDIT_SUBREDDIT=worldnews      # subreddit to poll (no r/ prefix)
POLL_INTERVAL=60                # seconds between polls

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=predictions.db          # relative path; override to /app/data/predictions.db in Docker
