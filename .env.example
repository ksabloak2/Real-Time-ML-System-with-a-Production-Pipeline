# ── Reddit API credentials ─────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=sentiment-bot/1.0 by u/your_reddit_username

# ── Ingestion settings ─────────────────────────────────────────────────────────
REDDIT_SUBREDDIT=worldnews      # subreddit to poll (no r/ prefix)
POLL_INTERVAL=60                # seconds between polls

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=predictions.db          # relative path; override to /app/data/predictions.db in Docker
